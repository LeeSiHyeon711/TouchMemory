# TouchMemory 환경변수 최종본 (FEAT-06)
# 이 파일은 Python에서 파싱하지 않는다. run.sh가 로드/export하여 os.environ으로 전달한다.
# 사용법: cp .env.example .env 후 값 채우기 (.env는 .gitignore로 커밋 제외됨)

# SQLite DB 파일 경로
DB_PATH=data/touchmemory.db

# 타임존
TZ=Asia/Seoul

# 중앙 API 서버 베이스 URL (FEAT-02에서 사용)
API_BASE_URL=http://127.0.0.1:8787

# 중앙 API 서버 바인딩 주소/포트 (FEAT-02)
API_HOST=127.0.0.1
API_PORT=8787

# Discord 봇 토큰 (FEAT-03)
DISCORD_TOKEN=

# 슬래시 커맨드를 즉시 반영할 Control Tower 길드(서버) id (FEAT-03)
GUILD_ID=

# 매일 능동 알림 발송 기본 시각 HH:MM, TZ 기준 (FEAT-04, settings에 없을 때만 사용)
NOTIFY_TIME=08:00

# 매일 능동 알림을 발송할 기본 채널 id (FEAT-04, settings에 없을 때만 사용)
NOTIFY_CHANNEL_ID=
